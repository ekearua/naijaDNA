APP_NAME=NaijaPulse API
APP_VERSION=0.1.0
ENVIRONMENT=dev
DEBUG=true
API_PREFIX=/api/v1
ENABLE_INGESTION_SCHEDULER=true
RUN_INGESTION_ON_STARTUP=false
INGESTION_STARTUP_TIMEOUT_SECONDS=20
INGESTION_STARTUP_LIMIT_PER_SOURCE=10
INGESTION_INTERVAL_SECONDS=21600
INGESTION_DEFAULT_LIMIT_PER_SOURCE=25
INGESTION_MAX_RECENT_RUNS=25
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/naijapulse
DATABASE_ECHO=false
NEWSAPI_API_KEY=
GNEWS_API_KEY=
ENABLE_RSS_SOURCES=true
ENABLE_NEWSAPI_SOURCE=false
ENABLE_GNEWS_SOURCE=false
AUTH_TOKEN_SECRET=change-me-in-env
AUTH_ACCESS_TOKEN_TTL_SECONDS=604800
STREAM_VIEWER_PRESENCE_TTL_SECONDS=75
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_TOKEN_TTL_SECONDS=3600
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RESPONSE_CACHE_ENABLED=true
CACHE_NEWS_TOP_TTL_SECONDS=900
CACHE_NEWS_LATEST_TTL_SECONDS=900
CACHE_POLLS_ACTIVE_TTL_SECONDS=900
CACHE_CATEGORIES_TTL_SECONDS=21600
CACHE_TAGS_TTL_SECONDS=21600

# Comma-separated list in JSON style for pydantic-settings
# CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080"]
